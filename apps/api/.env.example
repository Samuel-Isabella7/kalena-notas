# ===== Banco de dados =====
# Postgres do docker-compose sobe na porta 5433 (para não conflitar com outros projetos)
DATABASE_URL="postgresql://kalena:kalena_dev@localhost:5433/kalena_notas?schema=public"

# ===== Autenticação =====
JWT_SECRET="troque-este-segredo-em-producao-min-32-caracteres"
JWT_EXPIRES_IN="8h"

# ===== Servidor =====
PORT=3334
CORS_ORIGIN="http://localhost:3001"
# URL pública do app (usada no link de "esqueci minha senha")
WEB_URL="http://localhost:3001"

# ===== Criador inicial (seed) =====
# Esse é o ÚNICO usuário com papel CRIADOR criado no seed. Troque a senha após o primeiro login.
CRIADOR_NOME="Criador"
CRIADOR_EMAIL="criador@kalena.com.br"
CRIADOR_SENHA="criador123"

# ===== Google Drive (conta de serviço) =====
# Cole o JSON da conta de serviço em uma linha, OU informe o caminho de um arquivo .json.
# Deixe vazio para rodar em modo local (arquivos salvos em apps/api/uploads/).
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SERVICE_ACCOUNT_FILE=""
# ID da pasta compartilhada do Drive onde as notas serão salvas (em subpastas Ano/Mês/Dia).
GDRIVE_ROOT_FOLDER_ID=""

# ===== Omie =====
OMIE_BASE_URL="https://app.omie.com.br/api/v1"
# Conta de São Paulo
OMIE_SP_APP_KEY=""
OMIE_SP_APP_SECRET=""
# Conta do Rio de Janeiro
OMIE_RJ_APP_KEY=""
OMIE_RJ_APP_SECRET=""

# ===== Envio de e-mail (esqueci minha senha) =====
# Para Gmail/Google Workspace: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587,
# SMTP_USER=seu-email@kalena.com.br, SMTP_PASS=senha-de-app (16 dígitos gerada em myaccount.google.com).
# Deixe vazio para modo teste: o link de redefinição aparece no log da API (não envia e-mail real).
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Kalena Notas <nao-responda@kalena.com.br>"

# ===== Login com Google (SSO) =====
# Client ID do tipo "Aplicativo da Web" criado no Google Cloud Console.
# Deixe vazio para desabilitar o botão "Entrar com Google".
GOOGLE_OAUTH_CLIENT_ID=""
